{
  "id": null,
  "uid": "nexus-saas-overview",
  "title": "Nexus SaaS Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP Requests/s",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {"expr": "sum(rate(nexus_saas_requests_total[5m])) by (code)", "refId": "A", "legendFormat": "{{code}}"}
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Webhooks Received",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {"expr": "sum(rate(nexus_saas_webhooks_received_total[5m])) by (source)", "refId": "A", "legendFormat": "{{source}}"}
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Billing Checkouts (24h)",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
      "targets": [
        {"expr": "sum(increase(nexus_saas_billing_checkouts_total[24h]))", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"color": "blue", "value": null}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Notifications Sent",
      "gridPos": {"h": 8, "w": 18, "x": 6, "y": 8},
      "targets": [
        {"expr": "sum(rate(nexus_saas_notifications_sent_total[5m])) by (notification_type)", "refId": "A", "legendFormat": "{{notification_type}}"}
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Alert Evaluations",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16},
      "targets": [
        {"expr": "rate(nexus_saas_alerts_evaluated_total[5m])", "refId": "A", "legendFormat": "evaluations"}
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Alerts Fired",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 16},
      "targets": [
        {"expr": "sum(rate(nexus_saas_alerts_fired_total[5m])) by (rule_name)", "refId": "A", "legendFormat": "{{rule_name}}"}
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "HTTP Latency p95",
      "gridPos": {"h": 8, "w": 4, "x": 16, "y": 16},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(nexus_saas_request_duration_seconds_bucket[5m])) by (le))", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.5},
              {"color": "red", "value": 1}
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Error Rate (5xx)",
      "gridPos": {"h": 8, "w": 4, "x": 20, "y": 16},
      "targets": [
        {"expr": "sum(rate(nexus_saas_requests_total{code=~\"5..\"}[5m]))", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    }
  ]
}
