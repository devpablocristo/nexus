{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.example/schemas/ops/events/recommended_actions_created_v1.json",
  "title": "recommended_actions.created payload v1",
  "type": "object",
  "required": ["incident_id", "diagnosis_id", "actions"],
  "properties": {
    "incident_id": { "type": "string", "format": "uuid" },
    "diagnosis_id": { "type": "string", "format": "uuid" },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action_type", "scope", "params"],
        "properties": {
          "action_type": { "type": "string", "minLength": 1 },
          "scope": { "type": "object" },
          "ttl_seconds": { "type": "integer", "minimum": 0 },
          "params": { "type": "object" },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
