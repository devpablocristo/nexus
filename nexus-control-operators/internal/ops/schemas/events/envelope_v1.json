{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.example/schemas/ops/events/envelope_v1.json",
  "title": "Ops Event Envelope V1",
  "type": "object",
  "required": [
    "id",
    "event_type",
    "version",
    "occurred_at",
    "org_id",
    "correlation",
    "actor",
    "source",
    "payload"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "tool_call.finished",
        "policy.denied",
        "quota.exceeded",
        "tool_degraded",
        "anomaly.detected",
        "incident.opened",
        "incident.state_changed",
        "diagnosis.created",
        "recommended_actions.created",
        "action.proposed",
        "action.dry_run_ok",
        "action.dry_run_failed",
        "action.applied",
        "action.failed",
        "action.rolled_back",
        "comms.draft_created",
        "comms.awaiting_approval",
        "comms.sent_internal"
      ]
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "org_id": {
      "type": "string",
      "format": "uuid"
    },
    "correlation": {
      "type": "object",
      "properties": {
        "request_id": {
          "type": "string"
        },
        "incident_id": {
          "type": "string",
          "format": "uuid"
        },
        "action_id": {
          "type": "string",
          "format": "uuid"
        }
      },
      "additionalProperties": false
    },
    "actor": {
      "type": "object",
      "required": [
        "actor_type"
      ],
      "properties": {
        "actor_id": {
          "type": "string"
        },
        "actor_type": {
          "type": "string",
          "enum": [
            "agent",
            "human",
            "system"
          ]
        }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
