{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.example/schemas/ops/actions/export_audit_v1.json",
  "title": "Action export_audit v1",
  "type": "object",
  "required": ["action_type", "scope", "ttl_seconds", "params"],
  "properties": {
    "action_type": { "const": "export_audit" },
    "scope": {
      "type": "object",
      "required": ["level", "org_id"],
      "properties": {
        "level": { "const": "org" },
        "org_id": { "type": "string", "format": "uuid" }
      },
      "additionalProperties": false
    },
    "ttl_seconds": { "type": "integer", "minimum": 1 },
    "params": {
      "type": "object",
      "required": ["format"],
      "properties": {
        "filters": { "type": "object" },
        "format": { "type": "string", "enum": ["jsonl", "csv"] }
      },
      "additionalProperties": false
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
