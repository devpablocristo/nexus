COMPOSE_PROJECT_NAME=nexus-v2

NEXUS_HTTP_PORT=18080
NEXUS_CONTROL_PLANE_PORT=18082
NEXUS_CONTROL_WORKERS_PORT=18083
NEXUS_DATA_PLANE_POSTGRES_PORT=15430
NEXUS_CONTROL_PLANE_POSTGRES_PORT=15431
NEXUS_CONTROL_WORKERS_POSTGRES_PORT=15433
NEXUS_AUDIT_POSTGRES_PORT=15432

NEXUS_CONTROL_PLANE_URL=http://nexus-control-plane:8081
NEXUS_CONTROL_WORKERS_URL=http://nexus-control-workers:8082
NEXUS_DATA_PLANE_DATABASE_URL=postgres://postgres:postgres@data-plane-postgres:5432/nexus_data_plane?sslmode=disable
NEXUS_CONTROL_PLANE_DATABASE_URL=postgres://postgres:postgres@control-plane-postgres:5432/nexus_control_plane?sslmode=disable
NEXUS_CONTROL_WORKERS_DATABASE_URL=postgres://postgres:postgres@control-workers-postgres:5432/nexus_control_workers?sslmode=disable
NEXUS_AUDIT_DATABASE_URL=postgres://postgres:postgres@audit-postgres:5432/nexus_audit?sslmode=disable

NEXUS_ADMIN_API_KEY=nexus-admin-dev-key
NEXUS_DATA_PLANE_SERVICE_API_KEY=nexus-data-plane-service-dev-key
NEXUS_CONTROL_WORKERS_SERVICE_API_KEY=nexus-control-workers-service-dev-key
