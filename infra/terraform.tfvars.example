aws_region             = "us-east-1"
environment            = "staging"
domain                 = "nexus.example.com"
vpc_cidr               = "10.0.0.0/16"
core_db_instance_class = "db.t4g.micro"
saas_db_instance_class = "db.t4g.micro"
redis_node_type        = "cache.t4g.micro"
core_desired_count     = 1
saas_desired_count     = 1
control_desired_count  = 1
ai_desired_count       = 1

# Keep these false in real AWS deployments.
aws_skip_credentials_validation = false
aws_skip_requesting_account_id  = false
aws_skip_metadata_api_check     = false
aws_skip_region_validation      = false

# Use an ACM certificate ARN when enabling HTTPS on ALB/CloudFront.
certificate_arn = ""

# Route53 strategy
create_route53_zone   = false
existing_route53_zone_id = ""

# Sensitive variables must come from CI/CD or local secure env (never commit real values)
core_db_password = "CHANGE_ME"
saas_db_password = "CHANGE_ME"
redis_auth_token = ""

# Optional notifications receiver
alert_email = ""
