{
  "id": null,
  "title": "Nexus Starter Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Requests/s",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {"expr": "sum(rate(nexus_gateway_req_count{code!~\"5..\"}[5m]))", "refId": "A", "legendFormat": "2xx/4xx"},
        {"expr": "sum(rate(nexus_gateway_req_count{code=~\"5..\"}[5m]))", "refId": "B", "legendFormat": "5xx"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Run Throughput",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {"expr": "sum(rate(nexus_run_total_prom[5m])) by (status)", "refId": "A", "legendFormat": "{{status}}"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Run Latency p95 (ms)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(nexus_run_latency_ms_prom_bucket[5m])) by (le,status))", "refId": "A", "legendFormat": "{{status}}"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Blocked Decisions/s",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {"expr": "sum(rate(nexus_run_total_prom{decision=\"deny\"}[5m])) by (tool_name)", "refId": "A", "legendFormat": "{{tool_name}}"}
      ]
    }
  ]
}
