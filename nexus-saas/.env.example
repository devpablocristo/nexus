NEXUS_HTTP_PORT=8082
NEXUS_SAAS_DATABASE_URL=postgres://postgres:postgres@postgres-saas:5432/nexus_saas?sslmode=disable
NEXUS_MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
NEXUS_LOG_LEVEL=info
NEXUS_AUTH_ALLOW_API_KEY=true
NEXUS_AUTH_ENABLE_JWT=false
NEXUS_JWKS_URL=http://mock-tools:8081/.well-known/jwks.json
NEXUS_JWT_ISSUER=nexus-demo-issuer
NEXUS_JWT_AUDIENCE=nexus-core
NEXUS_JWT_ORG_CLAIM=org_id
NEXUS_JWT_ROLE_CLAIM=role
NEXUS_JWT_SCOPES_CLAIM=scopes
NEXUS_JWT_ACTOR_CLAIM=sub
NEXUS_OIDC_ENABLED=false
NEXUS_OIDC_ISSUER_URL=
NEXUS_OIDC_CLIENT_ID=
NEXUS_OIDC_CLIENT_SECRET=
NEXUS_OIDC_REDIRECT_URL=http://localhost:8082/v1/auth/oidc/callback
NEXUS_OIDC_SCOPES=openid profile email
NEXUS_SAAS_INTERNAL_KEY=saas-internal-key

