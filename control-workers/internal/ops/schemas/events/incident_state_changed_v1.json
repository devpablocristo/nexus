{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.example/schemas/ops/events/incident_state_changed_v1.json",
  "title": "incident.state_changed payload v1",
  "type": "object",
  "required": ["incident_id", "from_state", "to_state", "reason"],
  "properties": {
    "incident_id": { "type": "string", "format": "uuid" },
    "from_state": { "type": "string", "enum": ["OPEN", "DIAGNOSING", "MITIGATING", "MONITORING", "RESOLVED", "ESCALATED"] },
    "to_state": { "type": "string", "enum": ["OPEN", "DIAGNOSING", "MITIGATING", "MONITORING", "RESOLVED", "ESCALATED"] },
    "reason": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
