{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.example/schemas/ops/llm/executive_qa_response.json",
  "title": "ExecutiveQAResponse",
  "type": "object",
  "required": ["answer", "evidence_refs"],
  "properties": {
    "answer": { "type": "string", "minLength": 1 },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "recommended_action": {
      "type": "object",
      "required": ["action_type", "scope", "params"],
      "properties": {
        "action_type": {
          "type": "string",
          "enum": [
            "set_safe_mode",
            "pause_tool",
            "quarantine_tenant",
            "set_rate_limit",
            "rollback_last_mitigation",
            "export_audit"
          ]
        },
        "scope": { "type": "object" },
        "ttl_seconds": { "type": "integer", "minimum": 1 },
        "params": { "type": "object" },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
