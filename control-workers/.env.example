# === nexus-control-operators ===

# URL del servicio nexus-core
NEXUS_CORE_URL=http://nexus-core:8080

# Clave interna para autenticación con nexus-core (obligatoria)
OPERATOR_INTERNAL_KEY=your-internal-key

# Org ID por defecto (UUID)
NEXUS_DEFAULT_ORG_ID=

# Tamaño de batch para consumo de eventos
OPERATOR_BATCH_SIZE=100

# Intervalo de polling en milisegundos
OPERATOR_POLL_INTERVAL_MS=700

# Intervalo idle de recovery worker en milisegundos
OPERATOR_IDLE_INTERVAL_MS=15000

# Puerto del health server (/healthz, /readyz, /metrics)
OPERATOR_HEALTH_PORT=8090

# Directorio de persistencia de offsets/state
OPERATOR_DATA_DIR=/app/data

# Nivel de log (trace, debug, info, warn, error)
NEXUS_LOG_LEVEL=info
