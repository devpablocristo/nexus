{
  "id": null,
  "uid": "nexus-operators-overview",
  "title": "Nexus Operators Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Events Processed (control)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {"expr": "sum(rate(nexus_operators_events_processed_total[5m])) by (worker, status)", "refId": "A", "legendFormat": "{{worker}}/{{status}}"}
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Processing Duration p95 (control)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(nexus_operators_event_processing_duration_seconds_bucket[5m])) by (le, worker))", "refId": "A", "legendFormat": "{{worker}} p95"}
      ]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Consumer Offset",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 8},
      "targets": [
        {"expr": "nexus_operators_consumer_offset", "refId": "A"}
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Core API Calls (control)",
      "gridPos": {"h": 8, "w": 18, "x": 6, "y": 8},
      "targets": [
        {"expr": "sum(rate(nexus_operators_core_requests_total[5m])) by (status)", "refId": "A", "legendFormat": "{{status}}"}
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Events Consumed (AI)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {"expr": "rate(nexus_operator_events_consumed_total[5m])", "refId": "A", "legendFormat": "events"}
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Actions Applied (AI, 1h)",
      "gridPos": {"h": 8, "w": 4, "x": 12, "y": 16},
      "targets": [
        {"expr": "sum(increase(nexus_operator_actions_applied_total[1h]))", "refId": "A"}
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Incidents Opened (AI, 1h)",
      "gridPos": {"h": 8, "w": 4, "x": 16, "y": 16},
      "targets": [
        {"expr": "sum(increase(nexus_operator_incidents_opened_total[1h]))", "refId": "A"}
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Proposals Created (AI, 1h)",
      "gridPos": {"h": 8, "w": 4, "x": 20, "y": 16},
      "targets": [
        {"expr": "sum(increase(nexus_operator_proposals_created_total[1h]))", "refId": "A"}
      ]
    },
    {
      "id": 9,
      "type": "gauge",
      "title": "AI Last Cursor",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 24},
      "targets": [
        {"expr": "nexus_operator_last_cursor", "refId": "A"}
      ]
    }
  ]
}
