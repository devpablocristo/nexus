{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.example/schemas/ops/actions/set_safe_mode_v1.json",
  "title": "Action set_safe_mode v1",
  "type": "object",
  "required": ["action_type", "scope", "ttl_seconds", "params"],
  "properties": {
    "action_type": { "const": "set_safe_mode" },
    "scope": {
      "type": "object",
      "required": ["level"],
      "properties": {
        "level": { "type": "string", "enum": ["org", "global"] },
        "org_id": { "type": "string", "format": "uuid" }
      },
      "additionalProperties": false
    },
    "ttl_seconds": { "type": "integer", "minimum": 1 },
    "params": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
