{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.example/schemas/ops/actions/set_rate_limit_v1.json",
  "title": "Action set_rate_limit v1",
  "type": "object",
  "required": ["action_type", "scope", "ttl_seconds", "params"],
  "properties": {
    "action_type": { "const": "set_rate_limit" },
    "scope": {
      "type": "object",
      "required": ["level"],
      "properties": {
        "level": { "type": "string", "enum": ["org", "tool", "actor"] },
        "org_id": { "type": "string", "format": "uuid" },
        "tool_id": { "type": "string", "minLength": 1 },
        "actor_id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "ttl_seconds": { "type": "integer", "minimum": 1 },
    "params": {
      "type": "object",
      "required": ["rpm"],
      "properties": {
        "rpm": { "type": "integer", "minimum": 1 },
        "tool_id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
