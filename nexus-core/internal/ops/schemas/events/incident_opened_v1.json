{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.example/schemas/ops/events/incident_opened_v1.json",
  "title": "incident.opened payload v1",
  "type": "object",
  "required": ["incident_id", "severity", "state", "title", "summary", "fingerprint"],
  "properties": {
    "incident_id": { "type": "string", "format": "uuid" },
    "severity": { "type": "string", "enum": ["LOW", "MED", "HIGH", "CRIT"] },
    "state": { "type": "string", "enum": ["OPEN", "DIAGNOSING", "MITIGATING", "MONITORING", "RESOLVED", "ESCALATED"] },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "fingerprint": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
