{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.example/schemas/ops/events/anomaly_detected_v1.json",
  "title": "anomaly.detected payload v1",
  "type": "object",
  "required": ["fingerprint", "signal", "tool_name", "observed_value", "threshold_value"],
  "properties": {
    "fingerprint": { "type": "string", "minLength": 1 },
    "signal": { "type": "string", "minLength": 1 },
    "tool_name": { "type": "string", "minLength": 1 },
    "window_size": { "type": "integer", "minimum": 1 },
    "observed_value": { "type": "number" },
    "threshold_value": { "type": "number" },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": true
}
