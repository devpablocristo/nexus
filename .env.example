COMPOSE_PROJECT_NAME=nexus

# Puertos (host)
GOVERNANCE_PORT=18084
NEXUS_CONSOLE_PORT=13001
GOVERNANCE_POSTGRES_PORT=15434

# API keys del servicio governance
# GOVERNANCE_API_KEYS soporta metadata: name=secret|org_id=org-a|service_principal=true|scopes=scope1+scope2
GOVERNANCE_ADMIN_API_KEY=governance-admin-dev-key
GOVERNANCE_PROMETHEUS_API_KEY=governance-prometheus-dev-key
GOVERNANCE_PONTI_API_KEY=governance-ponti-dev-key

# Auth humano opcional para browser/API remota (OIDC/JWKS, por ej. Clerk)
GOVERNANCE_AUTH_ISSUER_URL=
GOVERNANCE_AUTH_AUDIENCE=

# AI (summarization + learning proposer — requiere Anthropic API key)
ANTHROPIC_API_KEY=

# Approval
GOVERNANCE_APPROVAL_TTL=3600

# Evidence signing
GOVERNANCE_SIGNING_KEY=governance-dev-signing-key-change-in-production

# Clerk auth (Console browser)
VITE_CLERK_PUBLISHABLE_KEY=
