# ============================================================
# Nexus — Environment Variables (.env.example)
# Copy to .env and adjust values for your environment.
# ============================================================

# ---------- Nexus Core ----------
NEXUS_HTTP_PORT=8080
NEXUS_DATABASE_URL=postgres://postgres:postgres@postgres:5432/nexus?sslmode=disable
NEXUS_HTTP_TIMEOUT_MS=5000
NEXUS_HTTP_MAX_RESPONSE_BYTES=1048576
NEXUS_MAX_BODY_BYTES=262144
NEXUS_LOG_LEVEL=info
NEXUS_RATE_LIMIT_DEFAULT_PER_MINUTE=60
NEXUS_RATE_LIMIT_BACKEND=inmemory
NEXUS_REDIS_URL=redis://redis:6379/0
NEXUS_SWAGGER_CDN=true
NEXUS_MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
NEXUS_AUTH_ALLOW_API_KEY=true
NEXUS_AUTH_ENABLE_JWT=true
NEXUS_JWKS_URL=http://mock-tools:8081/.well-known/jwks.json
NEXUS_JWT_ISSUER=nexus-demo-issuer
NEXUS_JWT_AUDIENCE=
NEXUS_JWT_ORG_CLAIM=org_id
NEXUS_JWT_ROLE_CLAIM=role
NEXUS_JWT_SCOPES_CLAIM=scopes
NEXUS_JWT_ACTOR_CLAIM=sub
NEXUS_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
NEXUS_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
NEXUS_CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-NEXUS-CORE-KEY,X-NEXUS-SCOPES,X-NEXUS-ACTOR,Idempotency-Key,X-Timeout-Ms
NEXUS_MIGRATIONS_DIR=/app/migrations
NEXUS_DISABLE_SSRF_PROTECTION=false
NEXUS_EGRESS_ALLOWLIST=mock-tools:8081
NEXUS_EXECUTION_LEASE_TOKEN_ISSUER=nexus-core
NEXUS_EXECUTION_LEASE_SIGNING_KEY=
NEXUS_IDEMPOTENCY_TTL_HOURS=24
NEXUS_TIMEOUT_BUDGET_DEFAULT_MS=10000
NEXUS_TIMEOUT_BUDGET_MIN_MS=1000
NEXUS_TIMEOUT_BUDGET_MAX_MS=30000
NEXUS_ACTION_TTL_SWEEP_SECONDS=15
NEXUS_ACTION_TTL_SWEEP_BATCH=200

# Circuit breaker (upstream tools)
NEXUS_CB_FAILURE_THRESHOLD=5
NEXUS_CB_HALF_OPEN_MAX=2
NEXUS_CB_RESET_TIMEOUT_SEC=30

# OpenTelemetry
NEXUS_OTEL_ENABLED=false
NEXUS_OTEL_SERVICE_NAME=nexus-core
NEXUS_OTLP_ENDPOINT=
NEXUS_OTLP_INSECURE=true

# Inter-service communication (core → saas, core → ai-operators)
NEXUS_AI_OPERATORS_URL=http://nexus-ai-operators:8000
NEXUS_AI_OPERATORS_INTERNAL_KEY=operator-internal-key
NEXUS_SAAS_URL=http://nexus-saas:8082
NEXUS_SAAS_INTERNAL_KEY=saas-internal-key
NEXUS_SAAS_TIMEOUT_MS=300
NEXUS_OPERATOR_API_KEY=nexus-ai-operators-local-key

# ---------- OIDC/SSO (optional) ----------
NEXUS_OIDC_ENABLED=false
NEXUS_OIDC_ISSUER_URL=
NEXUS_OIDC_CLIENT_ID=
NEXUS_OIDC_CLIENT_SECRET=
NEXUS_OIDC_REDIRECT_URL=http://localhost:8080/v1/auth/oidc/callback
NEXUS_OIDC_SCOPES="openid profile email"

# ---------- Clerk ----------
# Placeholders only. Replace with real Clerk values before enabling auth flows.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_WEBHOOK_SECRET=
# For real Clerk environments replace JWKS_URL and JWT_ISSUER above:
# NEXUS_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
# NEXUS_JWT_ISSUER=https://your-app.clerk.accounts.dev

# ---------- Stripe ----------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=
TOWER_BASE_URL=http://localhost:5173

# ---------- Notifications ----------
NOTIFICATION_BACKEND=noop
AWS_REGION=us-east-1
AWS_SES_FROM_EMAIL=noreply@nexus.example.com
AWS_SES_FROM_NAME=Nexus
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM_EMAIL=noreply@nexus.local
SMTP_USERNAME=
SMTP_PASSWORD=
NEXUS_ALERT_EVAL_INTERVAL=60s

# ---------- SaaS ----------
NEXUS_SAAS_DATABASE_URL=postgres://postgres:postgres@postgres-saas:5432/nexus_saas?sslmode=disable
NEXUS_SAAS_HTTP_PORT=8082
NEXUS_SAAS_RATE_LIMIT_RPS=100
NEXUS_SAAS_RATE_LIMIT_BURST=200
NEXUS_CORE_URL=http://nexus-core:8080

# ---------- AI Operators (Python/FastAPI) ----------
OPERATOR_APP_NAME=nexus-ai-operators
OPERATOR_ENV=dev
LLM_BACKEND=fallback
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
NEXUS_CORE_BASE_URL=http://nexus-core:8080
NEXUS_CORE_API_KEY=operator-internal-key
NEXUS_SAAS_BASE_URL=http://nexus-saas:8082
NEXUS_SAAS_API_KEY=nexus-ai-operators-local-key
NEXUS_CORE_TIMEOUT_SECONDS=5
NEXUS_SAAS_TIMEOUT_SECONDS=5
OPERATOR_INTERNAL_KEY=operator-internal-key
OPERATOR_MAX_BODY_BYTES=1048576
OPERATOR_ASSISTANT_RATE_LIMIT_PER_MIN=30
OPERATOR_POLL_INTERVAL_SECONDS=10
OPERATOR_POLL_BATCH_SIZE=100
OPERATOR_DENY_RATIO_THRESHOLD=0.35
OPERATOR_MIN_EVENTS_FOR_SIGNAL=20
OPERATOR_ACTION_COOLDOWN_SECONDS=300
OPERATOR_ACTION_TTL_SECONDS=300

# ---------- Control Operators (Go) ----------
OPERATOR_HEALTH_PORT=8090
OPERATOR_DATA_DIR=/app/data
OPERATOR_BATCH_SIZE=100
OPERATOR_POLL_INTERVAL_MS=700
OPERATOR_IDLE_INTERVAL_MS=15000
NEXUS_DEFAULT_ORG_ID=
NEXUS_DLQ_PATH=data/dead_letters.jsonl

# ---------- Tower (React/Vite) ----------
VITE_NEXUS_SAAS_URL=http://localhost:8082
VITE_NEXUS_CORE_URL=http://localhost:8080
VITE_NEXUS_API_KEY=nexus-core-local-key
VITE_NEXUS_SCOPES=admin:console:read,admin:console:write,audit:read
VITE_NEXUS_GRAFANA_URL=http://localhost:3001
VITE_ALLOW_API_KEY_FALLBACK=true

# ---------- Infra (ports & databases) ----------
NEXUS_POSTGRES_PORT=55432
NEXUS_SAAS_POSTGRES_PORT=55433
NEXUS_MOCK_TOOLS_PORT=8081
NEXUS_REDIS_PORT=6379
NEXUS_PROMETHEUS_PORT=9090
NEXUS_GRAFANA_PORT=3001
NEXUS_OPERATOR_PORT=8000
NEXUS_TOWER_PORT=5174
NEXUS_MAILHOG_SMTP_PORT=1025
NEXUS_MAILHOG_UI_PORT=8025
NEXUS_POSTGRES_PASSWORD=postgres
NEXUS_POSTGRES_USER=postgres

# ---------- Production vs Development ----------
# Dev:  docker compose up -d --build
#       Uses docker-compose.yml (includes mock-tools, prometheus, grafana).
#       Postgres and Redis ports are exposed to the host for debugging.
#       NEXUS_TOWER_PORT defaults to 5174 (or 5173 for Vite dev server).
#
# Prod: docker compose -f docker-compose.prod.yml up -d --build
#       Uses docker-compose.prod.yml (excludes dev-only services).
#       Postgres and Redis are internal-only (no host port exposure).
#       All services have resource limits, restart policies, and log rotation.
#       NEXUS_TOWER_PORT maps to nginx on container port 4173.
#
# For production, override at minimum:
#   NEXUS_MASTER_KEY        - generate a secure 32-byte base64 key
#   NEXUS_POSTGRES_PASSWORD - strong database password
#   NEXUS_DATABASE_URL      - update password to match NEXUS_POSTGRES_PASSWORD
#   VITE_NEXUS_SAAS_URL     - public URL of the Nexus SaaS API
#   NEXUS_TOWER_PORT        - set to the desired host port (e.g. 443 behind a reverse proxy)
#   CLERK_SECRET_KEY        - production Clerk secret
#   VITE_CLERK_PUBLISHABLE_KEY - production Clerk publishable key
#   STRIPE_SECRET_KEY       - production Stripe secret
