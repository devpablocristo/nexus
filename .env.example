COMPOSE_PROJECT_NAME=nexus

# Puertos (host)
GOVERNANCE_PORT=18084
NEXUS_CONSOLE_PORT=13001
GOVERNANCE_POSTGRES_PORT=15434

# API keys del servicio governance
# GOVERNANCE_API_KEYS soporta metadata: name=secret|org_id=org-a|service_principal=true|scopes=scope1+scope2
# En dev, GOVERNANCE_ADMIN_API_KEY debe ser el mismo valor que GOVERNANCE_API_KEY en el repo companion/.env.
GOVERNANCE_ADMIN_API_KEY=governance-admin-dev-key
GOVERNANCE_PROMETHEUS_API_KEY=governance-prometheus-dev-key
GOVERNANCE_PONTI_API_KEY=governance-ponti-dev-key

# Auth humano opcional para browser/API remota (OIDC/JWKS, por ej. Clerk)
GOVERNANCE_AUTH_ISSUER_URL=
GOVERNANCE_AUTH_AUDIENCE=

# Approval
GOVERNANCE_APPROVAL_TTL=3600

# Evidence signing
GOVERNANCE_SIGNING_KEY=governance-dev-signing-key-change-in-production

# ── Callbacks HTTP hacia Pymes (opcional; `extra_hosts` en governance ya expone host.docker.internal)
# Debe coincidir con GOVERNANCE_CALLBACK_TOKEN en el `.env` de Pymes (mismo valor que revisá ahí).
# Puertos por defecto del compose Pymes: cp-backend 8100→8080, ai 8200→8000.
GOVERNANCE_CALLBACK_TOKEN=local-review-callback-token
GOVERNANCE_APPROVAL_PENDING_CALLBACK_URLS=http://host.docker.internal:8100/v1/internal/v1/review-callback
GOVERNANCE_APPROVAL_RESOLVED_CALLBACK_URLS=http://host.docker.internal:8100/v1/internal/v1/review-callback,http://host.docker.internal:8200/v1/internal/review-callback

# Clerk auth (Console browser)
VITE_CLERK_PUBLISHABLE_KEY=
