# ---------- Nexus Core ----------
NEXUS_HTTP_PORT=8080
NEXUS_DATABASE_URL=postgres://postgres:postgres@postgres:5432/nexus?sslmode=disable
NEXUS_HTTP_TIMEOUT_MS=5000
NEXUS_HTTP_MAX_RESPONSE_BYTES=1048576
NEXUS_MAX_BODY_BYTES=262144
NEXUS_LOG_LEVEL=info
NEXUS_RATE_LIMIT_DEFAULT_PER_MINUTE=60
NEXUS_RATE_LIMIT_BACKEND=inmemory
NEXUS_REDIS_URL=redis://redis:6379/0
NEXUS_SWAGGER_CDN=true
NEXUS_MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
NEXUS_AUTH_ALLOW_API_KEY=true
NEXUS_AUTH_ENABLE_JWT=false
NEXUS_JWKS_URL=http://mock-tools:8081/.well-known/jwks.json
NEXUS_JWT_ISSUER=nexus-demo-issuer
NEXUS_JWT_AUDIENCE=nexus-core
NEXUS_JWT_ORG_CLAIM=org_id
NEXUS_JWT_ROLE_CLAIM=role
NEXUS_JWT_SCOPES_CLAIM=scopes
NEXUS_JWT_ACTOR_CLAIM=sub
NEXUS_OTEL_ENABLED=false
NEXUS_OTEL_SERVICE_NAME=nexus-core
NEXUS_OTLP_ENDPOINT=
NEXUS_OTLP_INSECURE=true
NEXUS_IDEMPOTENCY_TTL_HOURS=24
NEXUS_TIMEOUT_BUDGET_DEFAULT_MS=10000
NEXUS_TIMEOUT_BUDGET_MIN_MS=1000
NEXUS_TIMEOUT_BUDGET_MAX_MS=30000
NEXUS_DISABLE_SSRF_PROTECTION=false
NEXUS_EGRESS_ALLOWLIST=mock-tools:8081
NEXUS_LLM_PROVIDER=mock
NEXUS_LLM_MODEL=mock-default
NEXUS_OLLAMA_BASE_URL=http://localhost:11434
NEXUS_LLM_CLOUD_BASE_URL=https://api.openai.com/v1
NEXUS_LLM_CLOUD_API_KEY=
NEXUS_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
NEXUS_MIGRATIONS_DIR=/app/migrations
NEXUS_ACTION_TTL_SWEEP_SECONDS=15
NEXUS_ACTION_TTL_SWEEP_BATCH=200
NEXUS_OPERATOR_URL=http://nexus-ai-operators:8000
NEXUS_OPERATOR_INTERNAL_KEY=operator-internal-key

# ---------- OIDC/SSO (optional) ----------
NEXUS_OIDC_ENABLED=false
NEXUS_OIDC_ISSUER_URL=
NEXUS_OIDC_CLIENT_ID=
NEXUS_OIDC_CLIENT_SECRET=
NEXUS_OIDC_REDIRECT_URL=http://localhost:8080/v1/auth/oidc/callback
NEXUS_OIDC_SCOPES=openid profile email

# ---------- Operator ----------
# LLM_BACKEND: ollama | anthropic | fallback (default)
#   - fallback: no LLM, deterministic stub responses
#   - ollama:   local LLM via Ollama (run: docker compose --profile ollama up)
#   - anthropic: Claude API (requires ANTHROPIC_API_KEY)
LLM_BACKEND=fallback
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
NEXUS_CORE_BASE_URL=http://nexus-core:8080
NEXUS_CORE_API_KEY=nexus-ai-operators-local-key
NEXUS_OPERATOR_API_KEY=nexus-ai-operators-local-key
NEXUS_CORE_TIMEOUT_SECONDS=5
OPERATOR_POLL_INTERVAL_SECONDS=10
OPERATOR_POLL_BATCH_SIZE=100
OPERATOR_DENY_RATIO_THRESHOLD=0.35
OPERATOR_MIN_EVENTS_FOR_SIGNAL=20
OPERATOR_ACTION_COOLDOWN_SECONDS=300
OPERATOR_ACTION_TTL_SECONDS=300
OPERATOR_INTERNAL_KEY=operator-internal-key

# ---------- Tower ----------
VITE_NEXUS_CORE_URL=http://localhost:8080
VITE_NEXUS_OPERATOR_URL=http://localhost:8000
VITE_NEXUS_API_KEY=nexus-core-local-key
VITE_NEXUS_SCOPES=admin:console:read,admin:console:write,audit:read
VITE_OPERATOR_ACTION_KEY=operator-internal-key

# ---------- Infra ----------
NEXUS_POSTGRES_PORT=55432
NEXUS_MOCK_TOOLS_PORT=8081
NEXUS_REDIS_PORT=6379
NEXUS_PROMETHEUS_PORT=9090
NEXUS_GRAFANA_PORT=3000
NEXUS_OPERATOR_PORT=8000
NEXUS_TOWER_PORT=5174

# ---------- Production vs Development ----------
# Dev:  docker compose up -d --build
#       Uses docker-compose.yml (includes mock-tools, prometheus, grafana).
#       Postgres and Redis ports are exposed to the host for debugging.
#       NEXUS_TOWER_PORT defaults to 5174 (or 5173 for Vite dev server).
#
# Prod: docker compose -f docker-compose.prod.yml up -d --build
#       Uses docker-compose.prod.yml (excludes dev-only services).
#       Postgres and Redis are internal-only (no host port exposure).
#       All services have resource limits, restart policies, and log rotation.
#       NEXUS_TOWER_PORT maps to nginx on container port 4173.
#
# For production, override at minimum:
#   NEXUS_MASTER_KEY        - generate a secure 32-byte base64 key
#   NEXUS_POSTGRES_PASSWORD - strong database password
#   NEXUS_DATABASE_URL      - update password to match NEXUS_POSTGRES_PASSWORD
#   VITE_NEXUS_CORE_URL     - public URL of the Nexus Core API
#   VITE_NEXUS_OPERATOR_URL - public URL of the Nexus Operator API
#   NEXUS_TOWER_PORT        - set to the desired host port (e.g. 443 behind a reverse proxy)
NEXUS_POSTGRES_PASSWORD=postgres
NEXUS_POSTGRES_USER=postgres
