{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.example/schemas/world-event.json",
  "title": "Nexus World Event",
  "type": "object",
  "required": [
    "id",
    "run_id",
    "step_id",
    "seq",
    "org_id",
    "agent_id",
    "tool_name",
    "request_id",
    "created_at",
    "payload"
  ],
  "properties": {
    "id": { "type": "integer", "minimum": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "step_id": { "type": "integer", "minimum": 0 },
    "seq": { "type": "integer", "minimum": 0 },
    "org_id": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string" },
    "tool_name": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "required": [
        "event_version",
        "event_type",
        "timestamp",
        "run_id",
        "step_id",
        "seq",
        "org_id",
        "agent_id",
        "tool_name",
        "request_id"
      ],
      "properties": {
        "event_version": { "type": "integer", "minimum": 1 },
        "event_type": {
          "type": "string",
          "enum": [
            "tool.called",
            "tool.denied",
            "tool.rate_limited",
            "agent.spawned",
            "agent.moved",
            "agent.collided",
            "agent.blocked",
            "world.snapshot",
            "world.replayed",
            "world.seeded"
          ]
        },
        "timestamp": { "type": "string", "format": "date-time" },
        "run_id": { "type": "string", "minLength": 1 },
        "step_id": { "type": "integer", "minimum": 0 },
        "seq": { "type": "integer", "minimum": 0 },
        "org_id": { "type": "string", "minLength": 1 },
        "agent_id": { "type": "string" },
        "tool_name": { "type": "string", "minLength": 1 },
        "policy_id": { "type": ["string", "null"] },
        "request_id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
