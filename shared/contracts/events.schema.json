{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.example/schemas/operational-event.json",
  "title": "Nexus Operational Event",
  "type": "object",
  "required": ["id", "event_type", "org_id", "created_at", "payload"],
  "properties": {
    "id": { "type": "integer", "minimum": 1 },
    "event_type": {
      "type": "string",
      "enum": [
        "tool.call.completed",
        "action.applied",
        "action.rolled_back",
        "action.expired",
        "incident.opened",
        "incident.closed",
        "proposal.created",
        "proposal.approved",
        "proposal.rejected",
        "proposal.shadow_started"
      ]
    },
    "org_id": { "type": "string", "format": "uuid" },
    "created_at": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "additionalProperties": true,
      "description": "Event payload without raw PII; use references and deterministic DLP summary only."
    }
  },
  "additionalProperties": false
}
