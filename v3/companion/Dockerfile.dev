FROM golang:1.26-alpine

RUN apk add --no-cache git wget
RUN GOBIN=/usr/local/bin go install github.com/air-verse/air@v1.61.7

WORKDIR /workspace

COPY core/ai/go/go.mod ./core/ai/go/go.mod
COPY core/errors/go/go.mod ./core/errors/go/go.mod
COPY core/http/go/go.mod ./core/http/go/go.mod
COPY core/observability/go/go.mod ./core/observability/go/go.mod
COPY core/security/go/go.mod ./core/security/go/go.mod
COPY core/concurrency/go/go.mod ./core/concurrency/go/go.mod
COPY core/config/go/go.mod ./core/config/go/go.mod
COPY core/databases/postgres/go/go.mod ./core/databases/postgres/go/go.mod
COPY core/governance/go/go.mod ./core/governance/go/go.mod
COPY nexus/v3/companion/go.mod nexus/v3/companion/go.sum ./nexus/v3/companion/
WORKDIR /workspace/nexus/v3/companion
RUN go mod download

WORKDIR /workspace/nexus/v3/companion

EXPOSE 8080

CMD ["air", "-c", ".air.toml"]
