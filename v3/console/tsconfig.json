{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@devpablocristo/core-http": ["../../../core/http/ts/src/index.ts"],
      "@devpablocristo/core-http/*": ["../../../core/http/ts/src/*"],
      "@devpablocristo/core-browser": ["../../../core/browser/ts/src/index.ts"],
      "@devpablocristo/core-browser/*": ["../../../core/browser/ts/src/*"],
      "@devpablocristo/core-authn": ["../../../core/authn/ts/src/index.ts"],
      "@devpablocristo/core-authn/*": ["../../../core/authn/ts/src/*"]
    }
  },
  "include": ["src"]
}
