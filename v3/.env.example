COMPOSE_PROJECT_NAME=nexus-v3

# Puertos (host)
NEXUS_PORT=18084
NEXUS_COMPANION_PORT=18085
NEXUS_CONSOLE_PORT=13001
NEXUS_POSTGRES_PORT=15434

# API keys
# NEXUS_API_KEYS soporta metadata: name=secret|org_id=org-a|service_principal=true|scopes=scope1+scope2
NEXUS_ADMIN_API_KEY=nexus-admin-dev-key
NEXUS_PROMETHEUS_API_KEY=nexus-prometheus-dev-key
NEXUS_PONTI_API_KEY=nexus-ponti-dev-key
NEXUS_COMPANION_ADMIN_API_KEY=nexus-companion-admin-dev-key
# Auth humano opcional para browser/API remota (OIDC/JWKS, por ej. Clerk)
NEXUS_AUTH_ISSUER_URL=
NEXUS_AUTH_AUDIENCE=
# Segundos entre sincronizaciones tarea↔Nexus governance (0 = desactivar loop en segundo plano)
COMPANION_NEXUS_SYNC_INTERVAL_SEC=30
# Pymes Core (para watchers proactivos)
PYMES_BASE_URL=http://localhost:8100
PYMES_API_KEY=psk_local_admin
# Intervalo de watchers en segundos (0 = desactivar loop, ejecutar manualmente via API)
COMPANION_WATCHER_INTERVAL_SEC=0

# Companion LLM (providers: echo, ollama, anthropic, gemini)
NEXUS_LLM_PROVIDER=echo
NEXUS_LLM_API_KEY=
NEXUS_LLM_MODEL=qwen2.5:3b

# AI (Review summarization + learning proposer — requiere Anthropic API key)
ANTHROPIC_API_KEY=

# Approval
NEXUS_APPROVAL_TTL=3600

# Evidence signing
NEXUS_SIGNING_KEY=nexus-dev-signing-key-change-in-production

# Clerk auth (Console browser)
# Mismas credenciales que Pymes si comparten org
VITE_CLERK_PUBLISHABLE_KEY=
