COMPOSE_PROJECT_NAME=nexus-v3

# Puertos (host)
NEXUS_PORT=18084
NEXUS_CONSOLE_PORT=13001
NEXUS_POSTGRES_PORT=15434

# API keys
# NEXUS_API_KEYS soporta metadata: name=secret|org_id=org-a|service_principal=true|scopes=scope1+scope2
NEXUS_ADMIN_API_KEY=nexus-admin-dev-key
NEXUS_PROMETHEUS_API_KEY=nexus-prometheus-dev-key
NEXUS_PONTI_API_KEY=nexus-ponti-dev-key

# Auth humano opcional para browser/API remota (OIDC/JWKS, por ej. Clerk)
NEXUS_AUTH_ISSUER_URL=
NEXUS_AUTH_AUDIENCE=

# AI (summarization + learning proposer — requiere Anthropic API key)
ANTHROPIC_API_KEY=

# Approval
NEXUS_APPROVAL_TTL=3600

# Evidence signing
NEXUS_SIGNING_KEY=nexus-dev-signing-key-change-in-production

# Clerk auth (Console browser)
VITE_CLERK_PUBLISHABLE_KEY=
